@model IEnumerable<maxi_movie_mvc.Models.Pelicula>

@{
    ViewData["Title"] = "Películas";
}

<h1>Películas</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nueva</a>
</p>

<div class="table-responsive">
    <table id="peliculasTable" class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Título</th>
                <th>Poster</th>
                <th>Género</th>
                <th>Plataforma</th>
                <th>Duración (min)</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Titulo)
                </td>
                <td>
                    <img src="@item.PosterUrlPortada" height="80px" alt="@item.Titulo" />
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Genero.Descripcion)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Plataforma.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MinutosDuracion)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#peliculasTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                },
                "paging": true,
                "pageLength": 5,
                "ordering": true,
                "info": true,
                "searching": true,
                "responsive": true
            });
        });
    </script>
}
